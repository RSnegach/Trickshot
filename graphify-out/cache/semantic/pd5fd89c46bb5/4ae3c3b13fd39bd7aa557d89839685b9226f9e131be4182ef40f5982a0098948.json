{"nodes": [{"id": "multiplayer_framework", "label": "Trickshot Multiplayer Framework", "file_type": "concept", "source_file": "MULTIPLAYER.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Transport-agnostic netcode running over three interchangeable transports behind one interface; game code does not change between transports."}, {"id": "multiplayer_host_authoritative", "label": "Host-authoritative model", "file_type": "rationale", "source_file": "MULTIPLAYER.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One player (host) runs the physics/ragdoll sim; clients send input per tick and interpolate toward world snapshots. Chosen as the only sane model for a ragdoll-physics game because deterministic lockstep across machines is not realistic with PhysX ragdolls."}, {"id": "multiplayer_inettransport", "label": "INetTransport.cs (transport seam)", "file_type": "code", "source_file": "MULTIPLAYER.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "multiplayer_netmessages", "label": "NetMessages.cs (wire types + NetCodec)", "file_type": "code", "source_file": "MULTIPLAYER.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "multiplayer_netsession", "label": "NetSession.cs (host-authoritative session)", "file_type": "code", "source_file": "MULTIPLAYER.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Owns the slot table, routes messages, exposes per-slot input (host) and latest snapshot (client). Does not run the sim itself."}, {"id": "multiplayer_localtransport", "label": "LocalTransport.cs (in-process loopback)", "file_type": "code", "source_file": "MULTIPLAYER.md", "source_location": null, "source_url": null, "captured_at": null,